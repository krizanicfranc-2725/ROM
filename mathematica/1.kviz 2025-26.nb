        RowBox[{"x", "[", "1", "]"}], "==", "a"}], ",", 
       RowBox[{
        RowBox[{"x", "[", "2", "]"}], "==", 
        FractionBox["1", "2"]}]}], "}"}], ",", "x", ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "10"}], "}"}]}], "]"}], "]"}]}]], "Input",
