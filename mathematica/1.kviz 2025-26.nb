   RowBox[{"ToString", "[", 
    RowBox[{"N", "[", 
     RowBox[{
      RowBox[{"Pi", " ", 
       SuperscriptBox["r", "2"]}], ",", "7"}], "]"}], "]"}], 
   "<>", "\"\<.\>\""}]}]], "Input",
