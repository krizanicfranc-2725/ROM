Cell[TextData[{
 "c) Definirajte funkcijo ",
 StyleBox["h",
  FontSlant->"Italic"],
 " s predpisom ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", "10", 
         StyleBox["f", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "-", 
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "h(x) =10f(x)-g(x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5a7d3243-5c74-4f52-902f-03aeaa4ca1d6"],
 " in seznam \[OpenCurlyQuote]sez\[CloseCurlyQuote] dol\[ZHacek]ine 41, ki \
vsebuje numeri\[CHacek]ne vrednosti funkcije ",
 StyleBox["h",
  FontSlant->"Italic"],
 " v to\[CHacek]kah ",
 StyleBox["x=10,11,12,...,50",
  FontSlant->"Italic"],
 ". Nato definirajte \[SHacek]e seznam \
\[OpenCurlyQuote]sez3\[CloseCurlyQuote], ki vsebuje le tiste elemente iz \
seznama \[OpenCurlyQuote]sez\[CloseCurlyQuote], katerih celi del je deljiv s \
3."
}], "Text",
 CellChangeTimes->{{3.919489566201665*^9, 3.919489592283922*^9}, {
