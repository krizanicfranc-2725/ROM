Cell[TextData[{
 "a) Napi\[SHacek]ite  funkcijo \[OpenCurlyQuote]krog\[CloseCurlyQuote], ki  \
bo  sprejela  \[SHacek]tevilo \[OpenCurlyQuote]r\[CloseCurlyQuote] in izra\
\[CHacek]unala numeri\[CHacek]no vrednost obsega in plo\[SHacek]\[CHacek]ine \
kroga s polmerom \[OpenCurlyQuote]r\[CloseCurlyQuote]. Rezultat naj se izpi\
\[SHacek]e v obliki:\n\[OpenCurlyDoubleQuote]Obseg kroga s polmerom r=[r] je \
[obseg], plo\[SHacek]\[CHacek]ina pa [ploscina].\[CloseCurlyDoubleQuote],\n\
kjer [r] nadomestite z vne\[SHacek]eno vrednostjo polmera, [obseg] in \
[ploscina] pa z numeri\[CHacek]no vrednostjo obsega oz. \
plo\[SHacek]\[CHacek]ine pri vne\[SHacek]enem \[OpenCurlyQuote]r\
\[CloseCurlyQuote] na 7 decimalk natan\[CHacek]no (po decimalni piki naj se \
izpi\[SHacek]e \[SHacek]e 7 mest). Izra\[CHacek]unajte ",
 Cell[BoxData[
  FormBox[
   RowBox[{"'", 
    RowBox[{
     RowBox[{
      RowBox[{"krog", "[", 
       RowBox[{"5", "/", "6"}], "]"}], "'"}], "."}]}], TraditionalForm]],
  ExpressionUUID->"d4181720-6e94-4bed-bd62-ed38a87bcb14"]
}], "Text",
 CellChangeTimes->{{3.918736218873221*^9, 3.918736288439828*^9}, {
