a5c3d03d5941"],

Cell[TextData[{
 "Napi\[SHacek]ite funkcijo \[OpenCurlyQuote]fun\[CloseCurlyQuote], ki \
sprejme naravno \[SHacek]tevilo ",
 StyleBox["n",
  FontSlant->"Italic"],
 " in v primeru, da ima ",
 StyleBox["n",
  FontSlant->"Italic"],
 " sodo \[SHacek]tevilo \[SHacek]tevk, vrne njegovo zadnjo \[SHacek]tevko, v \
primeru, da ima liho \[SHacek]tevilo \[SHacek]tevk pa njegovo srednjo \
\[SHacek]tevko. Na primer, \[OpenCurlyQuote]fun[1234]\[CloseCurlyQuote] vrne \
\[OpenCurlyQuote]4\[CloseCurlyQuote], \[OpenCurlyQuote]fun[12345]\
\[CloseCurlyQuote] pa \[OpenCurlyQuote]3\[CloseCurlyQuote]. Uporabite lahko \
funkcijo \[OpenCurlyQuote]IntegerDigits\[CloseCurlyQuote]. "
}], "Text",
 CellChangeTimes->{{3.919491843743407*^9, 3.919491884837954*^9}, {
   3.91949203982038*^9, 3.919492110883181*^9}, {3.919492163591544*^9, 
   3.9194921777355328`*^9}, {3.919492210383447*^9, 3.919492245624755*^9}, 
   3.919589260728187*^9, {3.982750489301685*^9, 3.982750551768002*^9}, {
   3.982750586779656*^9, 3.982750668122333*^9}, {3.9832548796230927`*^9, 
   3.983255048203532*^9}, {3.983255084452597*^9, 3.9832551213355412`*^9}, {
   3.9833391182935624`*^9, 
   3.9833391187512636`*^9}},ExpressionUUID->"a9565728-d265-48c6-9406-\
d844bc311c73"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fun", "[", "n_", "]"}], ":=", 
  RowBox[{"If", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"EvenQ", "[", 
     RowBox[{"Length", "[", 
      RowBox[{"IntegerDigits", "[", "n", "]"}], "]"}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Last", "[", 
     RowBox[{"IntegerDigits", "[", "n", "]"}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"IntegerDigits", "[", "n", "]"}], "[", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Length", "[", 
          RowBox[{"IntegerDigits", "[", "n", "]"}], "]"}], "+", "1"}], ")"}], 
       "/", "2"}], "]"}], "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.983513274566988*^9, 3.9835133662573223`*^9}, {
  3.983513404162388*^9, 3.9835134213052826`*^9}, {3.983513451349249*^9, 
  3.9835135052403164`*^9}, {3.9835135561602077`*^9, 3.9835135976075*^9}},
