Cell[TextData[{
 "a) Definirajte funkciji ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          StyleBox["f", "TI"], 
          RowBox[{"(", 
            StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
          SubscriptBox["log", "10"], 
          RowBox[{"(", 
            RowBox[{
              FractionBox[
               RowBox[{
                 SuperscriptBox[
                  StyleBox["x", "TI"], "4"], "+", "5"}], 
               RowBox[{
                 SuperscriptBox[
                  StyleBox["x", "TI"], "3"], "-", "3"}]], "-", "3"}]}]}], 
        TraditionalForm], "errors" -> {}, "input" -> 
      "f(x) = \\log_{10}(\\frac{x^4+5}{x^3-3}-3", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], ")"}], TraditionalForm]],ExpressionUUID->
  "5367a0fc-b23b-40ad-a4b3-70fe2acca9d3"],
 " in   ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
         FractionBox["1", 
          RowBox[{
            StyleBox["x", "TI"], "-", "3"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "g(x) = \\frac{1}{x-3}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a691f5cf-8a4e-4c90-abd6-35c92f8e4ce5"],
 ". Funkciji ",
 StyleBox["f",
  FontSlant->"Italic"],
 " in ",
 StyleBox["g",
  FontSlant->"Italic"],
 " nari\[SHacek]ite v isti koordinatni sistem na intervalu [0,15]."
}], "Text",
 CellChangeTimes->{{3.919489566201665*^9, 3.919489592283922*^9}, {
   3.919489723063144*^9, 3.919489837014336*^9}, {3.9194898724870243`*^9, 
