Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{"Log", "[", 
    RowBox[{"10", ",", " ", 
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox["x", "4"], "+", "5"}], 
       RowBox[{
        SuperscriptBox["x", "3"], "-", "3"}]], "-", "3"}]}], "]"}]}], 
  RowBox[{"(*", 
   RowBox[{
   "brez", " ", "numeric", "\.08Q", " ", "mi", " ", "ne", " ", "re\[SHacek]i",
     " ", "FindRooot"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"g", "[", 
   RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
  FractionBox["1", 
   RowBox[{"x", "-", "3"}]]}]}], "Input",
 CellChangeTimes->{{3.9835136326025047`*^9, 3.9835136948352146`*^9}, {
  3.9835178438399525`*^9, 3.9835178454572124`*^9}, {3.9835180921207314`*^9, 
