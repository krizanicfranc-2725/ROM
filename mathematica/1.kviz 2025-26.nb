   3.9832577976410522`*^9, 3.983257801537059*^9}, {3.9832583781584635`*^9, 
   3.9832583863085933`*^9}, {3.983262124064267*^9, 3.983262193778672*^9}, {
   3.983262352785921*^9, 3.983262356296864*^9}, {3.9832786588511066`*^9, 
   3.9832787468118734`*^9}},ExpressionUUID->"8f96a848-b871-4591-853b-\
908107f5f2fc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FindRoot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", "x", "]"}], "==", 
    RowBox[{"g", "[", "x", "]"}]}], ",", "\[IndentingNewLine]", "\t\t", 
   RowBox[{"{", 
    RowBox[{"x", ",", "5"}], "}"}]}], "\[IndentingNewLine]", "\t\t", 
  "]"}]], "Input",
