Cell[TextData[{
 "e) Definirajte anonimno funkcijo h (s parametrom #) s predpisom ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], ",", 
             StyleBox["y", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["x", "TI"], "2"], "-", 
            SuperscriptBox[
             StyleBox["y", "TI"], "3"]}], "5"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "h(x,y) =\\frac{x^2-y^3}{5}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "88cfaff3-87e0-493a-af8a-415104b4d747"],
 ". Izra\[CHacek]unajte h(2,3) in nari\[SHacek]ite graf funkcije ",
 StyleBox["h",
  FontSlant->"Italic"],
 " na obmo\[CHacek]ju [-5,5]x[-5,5]."
}], "Text",
