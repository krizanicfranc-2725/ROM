Cell[TextData[{
 "b) S pomo\[CHacek]jo \[OpenCurlyQuote]RecurrenceTable\[CloseCurlyQuote] \
izra\[CHacek]unajte prvih 10 \[CHacek]lenov rekurzivnega zaporedja ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "+", "1"}]], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["n", "TI"]], "-", "4", 
         SubscriptBox[
          StyleBox["x", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "-", "1"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "x_{n + 1} = x_n - 4x_{n-1}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "182873b7-b519-4570-b7a0-075f1f4fdf73"],
 ", z za\[CHacek]etnim \[CHacek]lenom ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "1"], "\[LongEqual]", 
         StyleBox["a", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_1 = a", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d477c61b-964e-4340-bb68-694cd591eb35"],
 " in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], "2"], "\[LongEqual]", 
         FractionBox["1", "2"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "x_2 = \\frac{1}{2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4fac33c0-d305-45e7-a002-fa85693ce68d"],
 ", in jih shranite v seznam \[OpenCurlyQuote]zaporedje\[CloseCurlyQuote].  \
Rezultat \[CHacek]im bolj poenostavite. Nato izra\[CHacek]unajte vsoto vseh \
elementov seznama \[OpenCurlyQuote]zaporedje\[CloseCurlyQuote]."
}], "Text",
 CellChangeTimes->{{3.920516439150258*^9, 3.920516445280272*^9}, {
