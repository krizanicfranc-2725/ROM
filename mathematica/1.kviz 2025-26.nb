Cell[TextData[{
 "b)  Dolo\[CHacek]ite prese\[CHacek]i\[SHacek]\[CHacek]e funkcij ",
 StyleBox["f",
  FontSlant->"Italic"],
 " in ",
 StyleBox["g ",
  FontSlant->"Italic"],
 "(tj. tisto ",
 StyleBox["realno",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " \[SHacek]tevilo x, da velja f(x) = g(x))",
 ". Rezultat izpi\[SHacek]ite numeri\[CHacek]no. Z uporabo funkcije \
\[OpenCurlyQuote]Piecewise\[CloseCurlyQuote] nari\[SHacek]ite graf funkcije \
na [0,15], ki je levo od prese\[CHacek]i\[SHacek]\[CHacek]a enaka funkciji ",
 StyleBox["f",
  FontSlant->"Italic"],
 ", desno od prese\[CHacek]i\[SHacek]\[CHacek]a pa funkciji ",
 StyleBox["g",
  FontSlant->"Italic"],
 ". "
}], "Text",
 CellChangeTimes->{{3.920513802807349*^9, 3.920513826978806*^9}, {
   3.9205139514085627`*^9, 3.920514037606707*^9}, 3.920514099030876*^9, {
