Cell[BoxData[
 RowBox[{
  RowBox[{"CollZap", "[", 
   RowBox[{"m_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"RecurrenceTable", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"a", "[", "k", "]"}], "==", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"EvenQ", "[", 
          RowBox[{"a", "[", 
           RowBox[{"k", "-", "1"}], "]"}], "]"}], ",", 
         RowBox[{
          RowBox[{"a", "[", 
           RowBox[{"k", "-", "1"}], "]"}], "/", "2"}], ",", 
         RowBox[{
          RowBox[{"3", " ", "*", 
           RowBox[{"a", "[", 
            RowBox[{"k", "-", "1"}], "]"}]}], "+", "1"}]}], "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"a", "[", "1", "]"}], "==", "m"}]}], "}"}], 
    "\[IndentingNewLine]", "\[IndentingNewLine]", ",", "a", ",", 
    "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"k", ",", "1", ",", "n"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9820550148225727`*^9, 3.9820551680878754`*^9}, {
   3.9820552339001083`*^9, 3.982055234609762*^9}, {3.9820553516158886`*^9, 
