   RowBox[{"3", ",", "1", ",", "4", ",", "1", ",", "5", ",", "9", ",", "2"}], 
   "}"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Rezultat", ":", 
    RowBox[{"{", 
     RowBox[{
     "1", ",", "1", ",", "2", ",", "3", ",", "4", ",", "5", ",", "9"}], 
     "}"}]}], "*)"}]}]}], "Input",
