Cell[TextData[{
 "Napi\[SHacek]i funkcijo, ki sprejme naravni \[SHacek]tevili m in n in vrne \
seznam prvih n \[CHacek]lenov ",
 StyleBox["Collatzovega zaporedja",
  FontSlant->"Italic"],
 " za \[SHacek]tevilo m. Pomagaj si s funkcijo \
\[OpenCurlyDoubleQuote]RecurrenceTable\[CloseCurlyDoubleQuote]."
}], "Text",
 CellChangeTimes->{
  3.918737113432963*^9, {3.918737191383535*^9, 3.918737307637512*^9}, {
   3.918738735534246*^9, 3.918738861279017*^9}, {3.918738963334521*^9, 
