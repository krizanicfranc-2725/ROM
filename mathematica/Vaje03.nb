Cell[BoxData[
 RowBox[{"RecurrenceTable", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"a", "[", "n", "]"}], "==", 
      RowBox[{
       RowBox[{"a", "[", 
        RowBox[{"n", "-", "1"}], "]"}], "+", 
       RowBox[{"a", "[", 
        RowBox[{"n", "-", "2"}], "]"}]}]}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"a", "[", "1", "]"}], "==", "1"}], ",", 
     RowBox[{
      RowBox[{"a", "[", "2", "]"}], "==", "1"}]}], "}"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", ",", "a", ",", " ", "\n", 
   "  ", 
   RowBox[{"{", 
    RowBox[{"n", ",", "10"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9820547493942356`*^9, 3.9820547546223927`*^9}, {
