   3.982053643020159*^9},ExpressionUUID->"143bf3ee-2d9b-4676-8304-\
224af6927c5d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Collatz", "[", "m_", "]"}], ":=", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Mod", "[", 
      RowBox[{"m", ",", "2"}], "]"}], "==", "0"}], ",", 
    RowBox[{"m", "/", "2"}], ",", 
    RowBox[{
     RowBox[{"3", " ", "m"}], "+", "1"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.982053204995325*^9, 3.9820532159776917`*^9}, {
   3.9820532886608505`*^9, 3.9820533860136185`*^9}, {3.982053439175541*^9, 
   3.9820535154828625`*^9}, {3.9820545523528233`*^9, 3.9820545541911182`*^9}, 
   3.9820549450366135`*^9},
 CellLabel->"In[33]:=",ExpressionUUID->"a1eca44e-156b-d446-90f3-4acbf235b052"],

