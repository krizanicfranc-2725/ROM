227644e8d8fe"],

Cell[TextData[{
 "Napi\[SHacek]i  funkcijo quickSort, ki sprejme seznam in vrne urejen \
seznam. Za urejanje naj uporabi algoritem ",
 StyleBox["Quick sort",
  FontSlant->"Italic"],
 "."
}], "Text",
 CellChangeTimes->{{3.919321974718964*^9, 3.919322032589476*^9}, {
  3.9816527618300543`*^9, 
  3.9816527736932373`*^9}},ExpressionUUID->"90c84ab9-ce97-483d-ade2-\
613fa46deddc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "quickSort", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"quickSort", "[", "list_List", "]"}], ":=", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Length", "[", "list", "]"}], "<=", "1"}], ",", "list", ",", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"pivot", ",", "rest", ",", "left", ",", "right"}], "}"}], ",", 
      RowBox[{
       RowBox[{"pivot", "=", 
        RowBox[{"First", "[", "list", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"rest", "=", 
        RowBox[{"Rest", "[", "list", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"left", "=", 
        RowBox[{"Select", "[", 
         RowBox[{"rest", ",", 
          RowBox[{
           RowBox[{"#", "<=", "pivot"}], "&"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"right", "=", 
        RowBox[{"Select", "[", 
         RowBox[{"rest", ",", 
          RowBox[{
           RowBox[{"#", ">", "pivot"}], "&"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"quickSort", "[", "left", "]"}], ",", 
         RowBox[{"{", "pivot", "}"}], ",", 
         RowBox[{"quickSort", "[", "right", "]"}]}], "]"}]}]}], "]"}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.9820564580710087`*^9, 3.9820564580710087`*^9}},
 CellLabel->"In[88]:=",ExpressionUUID->"9c3fd3aa-d8b6-3e40-8a87-9a1437de64c1"],

