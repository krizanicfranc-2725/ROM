Cell[TextData[{
 "c) Definiraj funkcijo ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["f", "TI"], TraditionalForm], "errors" -> {}, "input" -> "f", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c375f561-b3e3-4370-ab61-ce09e6ceb0d7"],
 ", ki kot argument sprejme realno \[SHacek]tevilo ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["n", "TI"], TraditionalForm], "errors" -> {}, "input" -> "n", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "651aa032-397b-4964-b325-68c7e699a3fa"],
 " in vrne numeri\[CHacek]no vrednost `(izraz+izraz1)/izraz2` pri x=n. Izra\
\[CHacek]unaj f(2)."
}], "Text",
 CellChangeTimes->{{3.9195881603642406`*^9, 3.919588172591969*^9}, {
  3.9827488632981696`*^9, 3.9827489018415103`*^9}, {3.9827490230998254`*^9, 
