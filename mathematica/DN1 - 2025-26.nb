 RowBox[{
  RowBox[{"g", "[", "x_", "]"}], ":=", " ", 
  RowBox[{
   SuperscriptBox["x", "6"], "-", 
   RowBox[{"6", 
    SuperscriptBox["x", "2"]}], "+", "2"}]}]], "Input",
