 RowBox[{
  RowBox[{"h", " ", "=", " ", 
   RowBox[{
    RowBox[{"Sin", "[", 
     RowBox[{
      SuperscriptBox["#", "4"], "-", "2"}], "]"}], "&"}]}], ";"}]], "Input",
