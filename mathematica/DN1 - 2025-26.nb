Cell["\<\
b) Nari\[SHacek]i spodnjo sliko: zapolnjeni elipsi oran\[ZHacek]ne in zelene \
barve (prva  s sredi\[SHacek]\[CHacek]em v (0,0), druga s sredi\[SHacek]\
\[CHacek]em v (6,0), obe s polosema a=3,b=4) ter  rde\[CHacek] krog s sredi\
\[SHacek]\[CHacek]em v (3,0) in polmerom r=2. \
\>", "Text",
 CellChangeTimes->{{3.919493744803315*^9, 3.919493753324431*^9}, {
  3.919493833237421*^9, 3.919493942254839*^9}, {3.919590462028989*^9, 
