Cell[BoxData[
 RowBox[{" ", 
  RowBox[{"zap", " ", "=", " ", 
   RowBox[{"RecurrenceTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"a", "[", "n", "]"}], "==", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"a", "[", 
            RowBox[{"n", "-", "1"}], "]"}], "+", 
           RowBox[{"a", "[", 
            RowBox[{"n", "-", "2"}], "]"}]}], ")"}], "/", "2"}]}], ",", 
       RowBox[{
        RowBox[{"a", "[", "1", "]"}], "==", "c"}], ",", 
       RowBox[{
        RowBox[{"a", "[", "2", "]"}], "==", 
        FractionBox["c", "3"]}]}], "}"}], ",", "a", ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "10"}], "}"}]}], "]"}]}]}]], "Input",
