2b0a58b165c9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "n_", "]"}], ":=", 
  RowBox[{"N", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"izraz", "+", "izraz1"}], ")"}], "/", "izraz2"}], "/.", 
