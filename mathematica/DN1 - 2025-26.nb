Cell[TextData[{
 "d) Za funkcijo ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["f", "TI"], TraditionalForm], "errors" -> {}, "input" -> "f", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ff81c459-918e-41f9-8bc4-9275c4771e38"],
 " iz dela c) poenostavi izraz ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["f", "TI"], 
         RowBox[{"[", 
           RowBox[{
             SubscriptBox["log", "3"], "(", 
             RowBox[{
               RowBox[{"(", 
                 RowBox[{
                   SuperscriptBox[
                    StyleBox["x", "TI"], "2"], "-", "8", 
                   StyleBox["x", "TI"], 
                   StyleBox["z", "TI"], "+", "3", 
                   StyleBox["y", "TI"]}], ")"}], "-", 
               SuperscriptBox[
                RowBox[{"(", 
                  RowBox[{
                    StyleBox["x", "TI"], "-", "3"}], ")"}], "2"]}], ")"}], 
           "]"}]}], TraditionalForm], "errors" -> {}, "input" -> 
     "f[\\log_3((x^2 -8x z+ 3y)- (x - 3)^2)]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c18d1080-3736-4975-b36a-5b140b6e802f"],
 " za x = 6, y = -1/2 in z = -1."
}], "Text",
