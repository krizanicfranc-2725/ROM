  3.9828110623421493`*^9}},ExpressionUUID->"d1880a19-a725-402b-831f-\
f59eb66147de"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Graphics", "[", 
  RowBox[{"{", "\[IndentingNewLine]", 
   RowBox[{"Orange", ",", 
    RowBox[{"Ellipsoid", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "4"}], "}"}]}], "]"}], ",", "\[IndentingNewLine]", 
    "Green", ",", 
    RowBox[{"Ellipsoid", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"6", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "4"}], "}"}]}], "]"}], ",", "\[IndentingNewLine]", 
    "Red", ",", " ", 
