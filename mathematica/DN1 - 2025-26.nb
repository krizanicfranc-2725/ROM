1d18b39927df"],

Cell[TextData[{
 "a) Definiraj funkciji ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "6"], "-", "6", 
         SuperscriptBox[
          StyleBox["x", "TI"], "2"], "+", "2"}], TraditionalForm], 
     "errors" -> {}, "input" -> "g(x)= x^6 - 6x^2 + 2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3be41a48-7b75-400f-9332-5e1f01ed4a94"],
 " in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["h", "TI"], 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}], "\[LongEqual]", "sin", 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["x", "TI"], "4"], "-", "2"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> "h(x)=\\sin(x^4-2)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "edb0e68c-2235-404e-af28-64660d448b74"],
 ". Nato nari\[SHacek]i njuna grafa na intervalu [-2,2] v isti koordinatni \
sistem."
}], "Text",
 CellChangeTimes->{{3.9194925508565483`*^9, 3.919492568117846*^9}, {
  3.9194926118652563`*^9, 3.919492629232089*^9}, {3.91949275900605*^9, 
