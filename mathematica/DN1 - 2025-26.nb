Cell[TextData[{
 "e) Z uporabo funkcije `RecurrenceTable`izra\[CHacek]unaj prvih 10 \
\[CHacek]lenov zaporedja ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["n", "TI"]], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            SubscriptBox[
             StyleBox["a", "TI"], 
             RowBox[{
               StyleBox["n", "TI"], "-", "1"}]], "+", 
            SubscriptBox[
             StyleBox["a", "TI"], 
             RowBox[{
               StyleBox["n", "TI"], "-", "2"}]]}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "a_n = \\frac{a_{n-1}+a_{n-2}}{2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4fe0a413-ecb3-4918-9561-37fcf457fbf0"],
 " z za\[CHacek]etnima \[CHacek]lenoma  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["a", "TI"], "1"], "\[LongEqual]", 
         StyleBox["c", "TI"], ",", 
         SubscriptBox[
          StyleBox["a", "TI"], "2"], "\[LongEqual]", 
         FractionBox[
          StyleBox["c", "TI"], "3"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "a_1 = c, a_2 = \\frac{c}{3}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bb026c55-8fb6-4723-bc4a-77658a83ef9d"],
 ". Nato dolo\[CHacek]i po absolutni vrednosti najve\[CHacek]ji element izmed \
dobljenih 10 \[CHacek]lenov zaporedja v primeru, ko je c = -2."
}], "Text",
