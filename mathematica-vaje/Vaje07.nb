Cell[CellGroupData[{

Cell["Naloga 1", "Section",
 CellChangeTimes->{{3.922962110423855*^9, 3.922962115556046*^9}, {
  3.983953614881898*^9, 3.9839536199810066`*^9}, {3.9840183495110197`*^9, 
  3.9840183549254527`*^9}, {3.9840342956605186`*^9, 
  3.9840342966834297`*^9}},ExpressionUUID->"4f0b6a37-4ffd-4a95-9181-\
1ab5b4750985"],

Cell[TextData[{
 "Podana je matrika \n\tA = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {"1", 
       RowBox[{"-", "1", " "}], 
       RowBox[{"-", "1"}], 
       RowBox[{"-", "1"}]},
      {"2", "3", 
       RowBox[{"-", "12"}], "3"},
      {
       RowBox[{"-", "1"}], "3", "0", 
       RowBox[{"-", "1"}]},
      {
       RowBox[{"-", "2"}], "1", "4", 
       RowBox[{"-", "1"}]}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "285121ac-4cf1-413d-bdb0-3566900d8ac3"],
 ". \na) Dolo\[CHacek]ite rang matrike A. \nb) Matriko A pomno\[ZHacek]ite z \
1/3. \nc) Izra\[CHacek]unajte determinanto matrike A.\nd) Dolo\[CHacek]ite \
lastne vrednosti matrike A (ukaz ",
 StyleBox["Eigenvalues",
  FontSlant->"Italic"],
 ").\ne) Naj bo  B tista matrika oblike \n \t ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {"1", 
       RowBox[{"-", "5", " "}], 
       RowBox[{"-", "1"}], "14"},
      {"2", "3", "1", "3"},
      {"1", "3", 
       RowBox[{"-", "0.5"}], 
       RowBox[{"-", "1"}]},
      {
       RowBox[{"-", "2"}], "1", 
       RowBox[{"-", "2"}], "\[Alpha]"}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "a434b7e1-2c61-4cc7-bafe-748b16a29096"],
 ",\n   za katero velja ",
 StyleBox["det(B) = -195",
  FontSlant->"Italic"],
 ". Izra\[CHacek]unjate ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "+", "B"}], TraditionalForm]],ExpressionUUID->
  "4acb785c-92af-4254-9d3f-c3bcb7a16434"],
 ",  ",
 Cell[BoxData[
  FormBox["AB", TraditionalForm]],ExpressionUUID->
  "c4efe903-212a-4c70-9377-fa234eee0a38"],
 " in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["AB", 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "13dae251-1818-4e50-adc1-d6153ca934dc"],
 ". Rezultate izpi\[SHacek]ite v matri\[CHacek]ni obliki (ukaz ",
 StyleBox["MatrixForm",
  FontSlant->"Italic"],
 "). Kaj vrne ",
 StyleBox["A.B",
  FontSlant->"Italic"],
 " in kaj ",
 StyleBox["A*B",
  FontSlant->"Italic"],
 "?\nf) Naj bo ",
 StyleBox["a ",
  FontWeight->"Bold"],
 "prva",
 StyleBox[" ",
  FontWeight->"Bold"],
 "vrstica matrike A in ",
 StyleBox["b",
  FontWeight->"Bold"],
 " tretja vrstica matrike B (ustrezni vrstici iz matrik A in B \
izlo\[CHacek]ite z uporabo ustreznega ukaza, ne s prepisovanjem na roke). \
Izra\[CHacek]unjate skalarni produkt vektorjev ",
 StyleBox["a",
  FontWeight->"Bold"],
 " in ",
 StyleBox["b",
  FontWeight->"Bold"],
 "."
}], "Text",
